---
/**
 * Header.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Site-wide header with navigation links and a dark-mode toggle.
 * The active link is highlighted based on the current URL pathname.
 */

const NAV_LINKS = [
  { href: '/trails', label: 'Trails' },
  {
    label: 'Facilities',
    children: [
      { href: '/horse-arena', label: 'Horse Arena' },
      { href: '/dog-park', label: 'Dog Park' },
    ],
  },
  { href: '/events', label: 'Events' },
  {
    label: 'About Us',
    children: [
      { href: '/about', label: 'About' },
      { href: '/board', label: 'Board' },
      { href: '/contact', label: 'Contact Us' },
    ],
  },
  { href: '/join', label: 'Join' },
];

const pathname = new URL(Astro.request.url).pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/90 backdrop-blur dark:border-gray-700 dark:bg-gray-900/90">
  <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-2 sm:px-6">
    <!-- Logo / site name -->
    <a href="/" class="no-underline shrink-0">
      <img
        src="/images/mvta-logotype.png"
        alt="Meadow Vista Trails Association"
        class="h-14 w-auto dark:brightness-0 dark:invert"
      />
    </a>

    <!-- Desktop navigation -->
    <nav aria-label="Main navigation">
      <ul class="flex items-center gap-6 list-none m-0 p-0">
        {NAV_LINKS.map((item) => (
          <li class="relative group">
            {'children' in item ? (
              <>
                <button
                  type="button"
                  class:list={[
                    'flex items-center gap-1 text-sm font-medium transition-colors',
                    item.children.some(c => isActive(c.href))
                      ? 'text-brand-600 dark:text-brand-400'
                      : 'text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white',
                  ]}
                  aria-haspopup="true"
                >
                  {item.label}
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
                    <path d="M6 8L1 3h10z" />
                  </svg>
                </button>
                <ul class="absolute left-0 top-full mt-1 hidden min-w-max rounded-md border border-gray-200 bg-white py-1 shadow-lg group-hover:block dark:border-gray-700 dark:bg-gray-900 list-none m-0 before:absolute before:content-[''] before:h-1 before:w-full before:-top-1 before:left-0">
                  {item.children.map(({ href, label }) => (
                    <li>
                      <a
                        href={href}
                        class:list={[
                          'block px-4 py-2 text-sm no-underline transition-colors',
                          isActive(href)
                            ? 'text-brand-600 dark:text-brand-400'
                            : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50 dark:text-gray-400 dark:hover:text-white dark:hover:bg-gray-800',
                        ]}
                        aria-current={isActive(href) ? 'page' : undefined}
                      >
                        {label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={item.href}
                class:list={[
                  'text-sm font-medium no-underline transition-colors',
                  isActive(item.href)
                    ? 'text-brand-600 dark:text-brand-400'
                    : 'text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Dark mode toggle -->
    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle dark mode"
      class="rounded-md p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white transition-colors"
    >
      <!-- Sun icon (shown in dark mode) -->
      <svg
        id="icon-sun"
        class="hidden h-5 w-5 dark:block"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
      </svg>
      <!-- Moon icon (shown in light mode) -->
      <svg
        id="icon-moon"
        class="h-5 w-5 dark:hidden"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
      </svg>
    </button>
  </div>
</header>

<script>
  // Persist and apply dark mode preference
  const root = document.documentElement;
  const stored = localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

  if (stored === 'dark' || (!stored && prefersDark)) {
    root.classList.add('dark');
  }

  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = root.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
