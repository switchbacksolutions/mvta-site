---
/**
 * Footer.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Site-wide footer with copyright and navigation links.
 */

const year = new Date().getFullYear();

const FOOTER_LINKS = [
  { href: '/trails', label: 'Trails' },
  { href: '/events', label: 'Events' },
  { href: '/board', label: 'Board' },
  { href: '/licensing', label: 'Licensing' },
];
---

<footer class="border-t border-brand-800 bg-brand-800 dark:border-brand-900 dark:bg-brand-900">
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <div class="flex flex-col gap-6 sm:flex-row sm:justify-between">
      <!-- Site name + contact -->
      <div>
        <p class="text-base font-bold text-white">Meadow Vista Trails Association</p>
        <p class="mt-1 text-sm text-brand-200">Creating trails and community since 1995</p>
        <p class="mt-3 text-sm text-brand-200">P.O. Box 871, Meadow Vista, CA 95722</p>
        <a
          href="mailto:admin@mvtrails.org"
          class="text-sm text-brand-200 no-underline hover:text-white transition-colors"
        >
          admin@mvtrails.org
        </a>
      </div>

      <!-- Footer navigation -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-6 gap-y-2 list-none m-0 p-0">
          {FOOTER_LINKS.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-brand-200 no-underline hover:text-white transition-colors"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Copyright -->
    <p class="mt-8 text-center text-xs text-brand-300 dark:text-brand-400">
      &copy; {year} Meadow Vista Trails Association. All rights reserved.
    </p>
  </div>
</footer>
