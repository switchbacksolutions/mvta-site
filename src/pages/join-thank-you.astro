---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Application Submitted — MVTA"
  description="Thank you for your MVTA membership application."
>
  <main class="mx-auto max-w-3xl px-4 py-20 sm:px-6 text-center">
    <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-brand-100 dark:bg-brand-900/30 mb-6">
      <svg class="h-8 w-8 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>

    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Application received!</h1>

    <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
      Your membership application has been submitted. You will receive payment instructions by email
      with details on mailing a check to MVTA.
    </p>

    <p class="mt-6 text-sm text-gray-500 dark:text-gray-400">
      Questions? Email us at
      <a href="mailto:info@meadowvistatrails.org" class="text-brand-600 dark:text-brand-400 underline">info@meadowvistatrails.org</a>.
    </p>

    <a
      href="/"
      class="mt-8 inline-block btn-primary"
    >
      Return to home
    </a>
  </main>
</BaseLayout>
