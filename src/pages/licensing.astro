---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Licensing"
  description="Image, font, and icon licensing information for the Meadow Vista Trails Association website."
>
  <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Licensing</h1>
    <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
      Attribution and licensing information for assets used on this website.
    </p>

    <div class="prose-content mt-10">
      <h2>Images</h2>

      <h3>Unsplash</h3>
      <p>
        Some photography on this site is sourced from{' '}
        <a href="https://unsplash.com/" target="_blank" rel="noopener noreferrer">Unsplash</a>.
        Images are used under the{' '}
        <a href="https://unsplash.com/license" target="_blank" rel="noopener noreferrer">Unsplash License</a>,
        which allows free use for commercial and non-commercial purposes.
      </p>

      <h3>Freepik</h3>
      <p>
        Additional images including nature landscapes, team member photos, blog imagery,
        project photography, and service-related images are sourced from{' '}
        <a href="https://www.freepik.com/" target="_blank" rel="noopener noreferrer">Freepik</a>.
        These are used under the{' '}
        <a href="https://www.freepikcompany.com/legal" target="_blank" rel="noopener noreferrer">Freepik License</a>.
      </p>

      <h2>Fonts</h2>

      <h3>Poppins</h3>
      <p>
        The Poppins typeface is sourced from{' '}
        <a href="https://fonts.google.com/specimen/Poppins" target="_blank" rel="noopener noreferrer">Google Fonts</a>.
        You can use this font freely in your products and projects — print or digital,
        commercial or otherwise. You may not sell the font itself.
        <em>Note: This isn't legal advice — please consult a lawyer and review the full license for details.</em>
      </p>

      <h3>Karla</h3>
      <p>
        The Karla typeface is also sourced from{' '}
        <a href="https://fonts.google.com/specimen/Karla" target="_blank" rel="noopener noreferrer">Google Fonts</a>{' '}
        under the same terms as Poppins above.
      </p>

      <h2>Icons</h2>

      <h3>Social Icons — Font Awesome Free</h3>
      <p>
        Social media icons are from{' '}
        <a href="https://fontawesome.com" target="_blank" rel="noopener noreferrer">Font Awesome Free</a>,
        an open-source icon library. Used under the{' '}
        <a href="https://fontawesome.com/license/free" target="_blank" rel="noopener noreferrer">Font Awesome Free License</a>.
        These icons may be used freely in commercial and personal projects.
      </p>

      <h3>Outdoor Icons — Flaticon</h3>
      <p>
        Outdoor and trail-related icons are sourced from{' '}
        <a href="https://www.flaticon.com" target="_blank" rel="noopener noreferrer">Flaticon</a>,
        created by Freepik, IYIKON, and hamzaafzalrao.
      </p>
    </div>
  </main>
</BaseLayout>
