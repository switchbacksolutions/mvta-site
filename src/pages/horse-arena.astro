---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Meadow Vista Horse Arena"
  description="A full-sized equestrian arena and staging area available to the public on Combie Road in Meadow Vista, CA. Managed by the Meadow Vista Trails Association."
>
  <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Meadow Vista Horse Arena</h1>
    <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">
      A full-sized equestrian arena and staging area available to the public.
    </p>

    <div class="prose-content mt-10">
      <h2>About the Arena</h2>
      <p>
        The Meadow Vista Horse Arena is a full-size equestrian facility managed by MVTA on
        Placer County-owned land. The property includes:
      </p>
      <ul>
        <li>A full-size equestrian arena</li>
        <li>A smaller training arena</li>
        <li>The adjacent <a href="/dog-park">Meadow Vista Dog Park</a> with coursing obstacles</li>
        <li>Gated entry on Combie Road with perimeter fencing</li>
        <li>Parking suitable for multiple horse trailers</li>
      </ul>

      <h2>Access</h2>
      <p>
        The arena is open to the public — MVTA membership is not required. Gate keys are
        available from MVTA for a nominal fee. Contact us at{' '}
        <a href="mailto:admin@mvtrails.org">admin@mvtrails.org</a> for access details.
      </p>

      <h2>Volunteer &amp; Support Opportunities</h2>
      <p>
        MVTA is actively seeking support to keep the arena operational:
      </p>
      <ul>
        <li>Fundraising for a replacement shade structure</li>
        <li>Maintenance volunteers to keep the arena clean and safe</li>
      </ul>
      <p>
        If you'd like to help, <a href="/contact">get in touch</a> — every contribution makes
        a difference.
      </p>

      <h2>Administration</h2>
      <p>
        The arena operates on Placer County-owned land under MVTA management. For questions
        about the facility, contact{' '}
        <a href="mailto:admin@mvtrails.org">admin@mvtrails.org</a> or write to
        P.O. Box 871, Meadow Vista, CA 95722.
      </p>
    </div>

    <div class="mt-10 flex flex-wrap gap-4">
      <a href="/contact" class="btn-primary">Contact MVTA</a>
      <a href="/dog-park" class="btn-secondary">Dog Park →</a>
    </div>
  </main>
</BaseLayout>
