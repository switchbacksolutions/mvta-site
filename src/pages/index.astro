---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allTrails = await getCollection('trails');
const featuredTrailIds = ['olmstead-loop', 'euchre-bar', 'drivers-flat'];
const trails = featuredTrailIds
  .map((id) => allTrails.find((t) => t.id === id))
  .filter(Boolean);
---

<BaseLayout
  title="Meadow Vista Trails Association"
  description="Good trails. Great friends. Join a community of hikers, bikers, and riders dedicated to loving foothill trails in Meadow Vista, CA."
>
  <main>
    <!-- Hero -->
    <section class="bg-brand-700 overflow-hidden">
      <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20 grid md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-brand-300 mb-3">
            Meadow Vista, CA · Since 1995
          </p>
          <h1 class="text-5xl sm:text-6xl font-bold text-white text-balance leading-tight">
            Good trails.<br />
            <span class="text-brand-200">Great friends.</span>
          </h1>
          <p class="mt-4 max-w-xl text-lg text-brand-100 text-pretty leading-relaxed">
            Join a community of like-minded hikers, bikers, and riders dedicated to
            loving foothill trails in Meadow Vista and the surrounding foothills.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary">
              Join MVTA
            </a>
            <a
              href="/trails"
              class="inline-flex items-center gap-2 rounded-md border-2 border-white/70 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/10 hover:border-white transition-colors duration-150"
            >
              See Trails
            </a>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-2xl aspect-[4/3] ring-1 ring-white/10">
          <img
            src="/images/meadow-vista-sunset.jpg"
            alt="Sunset over Meadow Vista foothills"
            class="w-full h-full object-cover object-center"
          />
        </div>
      </div>
    </section>

    <!-- Stats bar -->
    <section class="bg-brand-500 text-white">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <dl class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-brand-400">
          {[
            { value: '1995', label: 'Founded' },
            { value: '25+', label: 'Trail miles' },
            { value: '2', label: 'Facilities managed' },
            { value: '9', label: 'Volunteer board members' },
          ].map((s) => (
            <div class="flex flex-col items-center py-8 px-4 text-center">
              <dt class="text-4xl font-bold text-white">{s.value}</dt>
              <dd class="mt-1 text-sm font-medium text-brand-200 uppercase tracking-wide">{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- Mission -->
    <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <div class="grid gap-10 md:grid-cols-2 md:items-center">
        <div>
          <span class="text-xs font-semibold uppercase tracking-widest text-accent-500">Our Mission</span>
          <h2 class="mt-2 text-3xl font-bold text-gray-900 dark:text-white text-balance">
            Dedicated to trails and community
          </h2>
          <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">
            Meadow Vista Trails Association is dedicated to establishing and maintaining safe trails
            in Meadow Vista and the surrounding areas — serving walkers, joggers, cyclists, and equestrians since 1995.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/about" class="btn-secondary">Learn More</a>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-xl aspect-[4/3]">
          <img
            src="/images/trails/olmstead-loop/hero.jpeg"
            alt="Hikers on the Olmstead Loop trail"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </section>

    <!-- Featured trails -->
    <section class="bg-brand-50 dark:bg-gray-900 py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="flex items-baseline justify-between mb-8">
        <div>
          <span class="text-xs font-semibold uppercase tracking-widest text-accent-500">Get Outside</span>
          <h2 class="mt-1 text-3xl font-bold text-gray-900 dark:text-white">Featured Trails</h2>
        </div>
        <a href="/trails" class="text-sm font-medium text-brand-600 no-underline hover:underline dark:text-brand-400">
          View all trails →
        </a>
      </div>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 list-none m-0 p-0">
        {trails.map((trail) => (
          <li class="card !p-0 overflow-hidden">
            {trail.data.heroImage && (
              <img
                src={trail.data.heroImage}
                alt={trail.data.title}
                class="w-full h-48 object-cover"
              />
            )}
            <div class="p-5">
              <span class="inline-block rounded-full bg-brand-100 px-3 py-0.5 text-xs font-medium text-brand-700 dark:bg-brand-900 dark:text-brand-200 mb-3">
                {trail.data.trailType} · {trail.data.distance}
              </span>
              <h3 class="font-semibold text-gray-900 dark:text-white text-balance">
                {trail.data.title}
              </h3>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">{trail.data.description}</p>
              <p class="mt-3 text-xs text-brand-600 dark:text-brand-400 font-medium">{trail.data.difficulty}</p>
            </div>
          </li>
        ))}
      </ul>
      </div>
    </section>

    <!-- Facilities -->
    <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <div class="text-center mb-10">
        <span class="text-xs font-semibold uppercase tracking-widest text-accent-500">Open to the Public</span>
        <h2 class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">Facilities</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
          <a href="/horse-arena" class="card group no-underline block">
            <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
              Meadow Vista Horse Arena
            </h3>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
              A full-sized equestrian arena and staging area available to the public, located on Combie Road. Gate keys available through MVTA.
            </p>
            <span class="mt-4 inline-block text-sm text-brand-600 dark:text-brand-400 font-medium">Learn more →</span>
          </a>
          <a href="/dog-park" class="card group no-underline block">
            <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
              Meadow Vista Dog Park
            </h3>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
              A dog park and agility course located behind the Horse Arena, open to the public.
            </p>
            <span class="mt-4 inline-block text-sm text-brand-600 dark:text-brand-400 font-medium">Learn more →</span>
          </a>
        </div>
    </section>

    <!-- Recent news -->
    {recentPosts.length > 0 && (
      <section class="bg-brand-50 dark:bg-gray-900 py-16">
        <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <div class="flex items-baseline justify-between mb-8">
          <div>
            <span class="text-xs font-semibold uppercase tracking-widest text-accent-500">Stay Informed</span>
            <h2 class="mt-1 text-3xl font-bold text-gray-900 dark:text-white">Latest News</h2>
          </div>
          <a href="/blog" class="text-sm font-medium text-brand-600 no-underline hover:underline dark:text-brand-400">
            View all →
          </a>
        </div>
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 list-none m-0 p-0">
          {recentPosts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="group block card h-full no-underline">
                {post.data.tags.length > 0 && (
                  <div class="mb-2 flex flex-wrap gap-1">
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span class="tag-pill">{tag}</span>
                    ))}
                  </div>
                )}
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400 transition-colors text-balance">
                  {post.data.title}
                </h3>
                <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-3">
                  {post.data.description}
                </p>
                <p class="mt-4 text-xs text-gray-400 dark:text-gray-500">
                  <FormattedDate date={post.data.pubDate} format="short" />
                </p>
              </a>
            </li>
          ))}
        </ul>
        </div>
      </section>
    )}

    <!-- Join CTA -->
    <section class="bg-accent-500">
      <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 text-center">
        <h2 class="text-3xl font-bold text-white">Become a Member</h2>
        <p class="mt-4 text-lg text-white/90 max-w-xl mx-auto">
          Support trail maintenance, connect with your community, and help keep Meadow Vista's trails open for everyone.
          Individual memberships start at just $25/year.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-md bg-white px-6 py-3 text-sm font-semibold text-accent-600 shadow-sm hover:bg-gray-50 transition-colors"
          >
            Join Today
          </a>
          <a
            href="/about"
            class="inline-flex items-center gap-2 rounded-md border-2 border-white px-6 py-3 text-sm font-semibold text-white hover:bg-white/10 transition-colors"
          >
            Learn More
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
