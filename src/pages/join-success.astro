---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Payment Received — MVTA"
  description="Thank you for your MVTA membership payment."
>
  <main class="mx-auto max-w-3xl px-4 py-20 sm:px-6 text-center">
    <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30 mb-6">
      <svg class="h-8 w-8 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Payment received!</h1>

    <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
      Your MVTA membership payment was processed successfully. A receipt has been sent to your email address.
      Welcome to the trail community!
    </p>

    <p class="mt-6 text-sm text-gray-500 dark:text-gray-400">
      If you requested an arena parking key, it will be mailed to the address you provided.
      Questions? Email us at
      <a href="mailto:info@meadowvistatrails.org" class="text-brand-600 dark:text-brand-400 underline">info@meadowvistatrails.org</a>.
    </p>

    <a
      href="/"
      class="mt-8 inline-block btn-primary"
    >
      Return to home
    </a>
  </main>
</BaseLayout>
