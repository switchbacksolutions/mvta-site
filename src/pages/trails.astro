---
import BaseLayout from '@/layouts/BaseLayout.astro';

const trails = [
  {
    name: 'Olmstead Loop Trail',
    aka: 'Knickerbocker Trail',
    type: 'Loop',
    distance: '10 miles',
    difficulty: 'Moderate',
    access: 'From Auburn, head up Cool on Highway 49.',
    description: 'Spectacular views of the Sierra Range and canyon views make this one of the most rewarding loops in the area. A classic foothill trail accessible from Auburn.',
  },
  {
    name: 'Euchre Bar – Alta',
    aka: null,
    type: 'Out and Back',
    distance: '5 miles',
    difficulty: 'Moderate',
    access: null,
    description: 'An old mining trail that descends to the American River and continues to Humbug Creek and back. Additional routing options available for those seeking a longer adventure.',
  },
  {
    name: 'Drivers Flat to Ruck-a-Chucky',
    aka: null,
    type: 'Out and Back',
    distance: '2.5 miles',
    difficulty: 'Moderate',
    access: 'Trailer parking available at Drivers Flat Road.',
    description: 'A dirt road that descends to the American River at Ruck-a-Chucky. Trailer parking is available, making this a great option for equestrians.',
  },
  {
    name: 'Hidden Falls Regional Park',
    aka: null,
    type: 'Out and Back',
    distance: null,
    difficulty: 'Moderate',
    access: 'Located at the far end of the parking lot.',
    description: 'A popular Placer County Regional Park with multiple trail options for hikers, mountain bikers, and equestrians. Beautiful waterfalls and oak woodlands.',
  },
  {
    name: 'Stevens Trail – Colfax Side',
    aka: null,
    type: 'Out and Back',
    distance: '7.2 miles',
    difficulty: 'Moderate',
    access: 'Accessed from the Colfax exit off I-80.',
    description: 'A historic trail that drops down from Colfax to the North Fork of the American River. Stunning canyon views and a challenging descent make this a memorable out-and-back.',
  },
  {
    name: 'Plumtree Road – Bear River Canal Loop',
    aka: null,
    type: 'Loop',
    distance: '4.8 miles',
    difficulty: 'Moderate',
    access: 'Take Plumtree Road to the turnout.',
    description: 'A pleasant loop along Plumtree Road and the Bear River Canal. Good for all trail users including walkers, joggers, and cyclists.',
  },
];
---

<BaseLayout
  title="Trails"
  description="Explore trails near Meadow Vista, CA — hiking, mountain biking, and equestrian routes in the Sierra Nevada foothills maintained and promoted by MVTA."
>
  <main class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Trails</h1>
    <p class="mt-4 text-xl text-gray-600 dark:text-gray-400 text-pretty">
      Your next adventure is closer to home than you think! Explore these foothill trails
      near Meadow Vista, maintained and championed by MVTA volunteers.
    </p>

    <ul class="mt-12 space-y-6 list-none m-0 p-0">
      {trails.map((trail) => (
        <li class="card">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
                {trail.name}
              </h2>
              {trail.aka && (
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">aka {trail.aka}</p>
              )}
            </div>
            <div class="flex flex-wrap gap-2 shrink-0">
              <span class="tag-pill">{trail.type}</span>
              {trail.distance && <span class="tag-pill">{trail.distance}</span>}
              <span class="tag-pill">{trail.difficulty}</span>
            </div>
          </div>
          <p class="mt-3 text-gray-600 dark:text-gray-400">{trail.description}</p>
          {trail.access && (
            <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">
              <strong class="text-gray-700 dark:text-gray-300">Access:</strong> {trail.access}
            </p>
          )}
        </li>
      ))}
    </ul>

    <div class="mt-12 card bg-brand-50 dark:bg-brand-900/30 border-brand-200 dark:border-brand-700">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Know a trail we're missing?</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        MVTA members help identify, maintain, and improve trails throughout the Meadow Vista area.
        If you have a trail to suggest or want to get involved, reach out to us.
      </p>
      <a href="/contact" class="mt-4 inline-block btn-primary">Get Involved</a>
    </div>
  </main>
</BaseLayout>
