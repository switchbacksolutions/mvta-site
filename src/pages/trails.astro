---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const trails = await getCollection('trails');

const difficultyColor: Record<string, string> = {
  Easy: 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300',
  Moderate: 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
  Challenging: 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300',
};

const allUses = [...new Set(trails.flatMap((t) => t.data.uses))].sort();
---

<BaseLayout
  title="Trails"
  description="Explore trails near Meadow Vista, CA — hiking, mountain biking, and equestrian routes in the Sierra Nevada foothills maintained and promoted by MVTA."
>
  <main class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Trails</h1>
    <p class="mt-4 text-xl text-gray-600 dark:text-gray-400 text-pretty">
      Your next adventure is closer to home than you think! Explore these foothill trails
      near Meadow Vista, maintained and championed by MVTA volunteers.
    </p>

    <!-- Search and tag filter controls -->
    <div class="mt-8 space-y-3">
      <input
        id="trail-search"
        type="search"
        placeholder="Search trails by name…"
        class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder:text-gray-500"
      />
      <div class="flex flex-wrap gap-2" id="tag-filters" aria-label="Filter by use">
        {allUses.map((use) => (
          <button
            type="button"
            data-tag={use.toLowerCase()}
            class="tag-filter-btn tag-pill cursor-pointer border border-transparent transition-colors hover:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50"
          >
            {use}
          </button>
        ))}
      </div>
    </div>

    <p id="no-results" class="mt-10 hidden text-center text-gray-500 dark:text-gray-400">
      No trails match your search or filters.
    </p>

    <ul id="trails-list" class="mt-8 grid gap-6 list-none m-0 p-0 sm:grid-cols-2">
      {trails.map((trail) => (
        <li
          data-title={trail.data.title.toLowerCase()}
          data-uses={trail.data.uses.map((u) => u.toLowerCase()).join('|')}
        >
          <a
            href={`/trails/${trail.id}`}
            class="group flex flex-col h-full rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden hover:shadow-md transition-shadow no-underline dark:border-gray-700 dark:bg-gray-800"
          >
            {trail.data.heroImage && (
              <div class="h-48 w-full overflow-hidden">
                <img
                  src={trail.data.heroImage}
                  alt={trail.data.title}
                  class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            )}
            <div class="flex flex-col flex-1 p-5">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                  {trail.data.title}
                </h2>
                <div class="flex flex-wrap gap-1.5 shrink-0">
                  <span class:list={['inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold', difficultyColor[trail.data.difficulty]]}>
                    {trail.data.difficulty}
                  </span>
                </div>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400 flex-1 line-clamp-3">{trail.data.description}</p>
              <div class="mt-4 flex flex-wrap gap-1.5">
                <span class="tag-pill">{trail.data.trailType}</span>
                {trail.data.distance && <span class="tag-pill">{trail.data.distance}</span>}
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-12 card bg-brand-50 dark:bg-brand-900/30 border-brand-200 dark:border-brand-700">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Know a trail we're missing?</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        MVTA members help identify, maintain, and improve trails throughout the Meadow Vista area.
        If you have a trail to suggest or want to get involved, reach out to us.
      </p>
      <a href="/contact" class="mt-4 inline-block btn-primary">Get Involved</a>
    </div>
  </main>
</BaseLayout>

<script>
  const searchInput = document.getElementById('trail-search') as HTMLInputElement;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn');
  const trailItems = document.querySelectorAll<HTMLLIElement>('#trails-list li');
  const noResults = document.getElementById('no-results')!;

  const activeTags = new Set<string>();

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    trailItems.forEach((item) => {
      const title = item.dataset.title ?? '';
      const uses = item.dataset.uses ?? '';

      const matchesSearch = !query || title.includes(query);
      const matchesTags =
        activeTags.size === 0 ||
        [...activeTags].every((tag) => uses.split('|').some((u) => u === tag));

      const visible = matchesSearch && matchesTags;
      item.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    noResults.classList.toggle('hidden', visibleCount > 0);
  }

  searchInput.addEventListener('input', applyFilters);

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        btn.setAttribute('aria-pressed', 'false');
        btn.classList.remove(
          'bg-brand-600',
          'text-white',
          'dark:bg-brand-500',
          'border-brand-600',
          'dark:border-brand-500',
        );
        btn.classList.add('border-transparent');
      } else {
        activeTags.add(tag);
        btn.setAttribute('aria-pressed', 'true');
        btn.classList.remove('border-transparent');
        btn.classList.add(
          'bg-brand-600',
          'text-white',
          'dark:bg-brand-500',
          'border-brand-600',
          'dark:border-brand-500',
        );
      }
      applyFilters();
    });
  });
</script>
