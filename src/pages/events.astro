---
import BaseLayout from '@/layouts/BaseLayout.astro';

const events = [
  {
    name: 'MVTA Board Meeting',
    date: 'September 3',
    location: null,
    description: 'Monthly board meeting for MVTA. All members are welcome to attend.',
  },
  {
    name: 'MVTA Group Hike',
    date: 'September 25',
    location: 'Weimar Institute',
    description: 'MVTA group hike at the Weimar Institute. A great opportunity to explore local trails with fellow members.',
  },
  {
    name: 'Pioneer Day 2025',
    date: 'June 7, 2025',
    location: 'Meadow Vista',
    description: "Stop by our booth or see us in the parade at Meadow Vista's Pioneer Day Celebration! A fun community event for the whole family.",
  },
];
---

<BaseLayout
  title="Events"
  description="Upcoming events from the Meadow Vista Trails Association — group hikes, board meetings, and community gatherings."
>
  <main class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Events</h1>
    <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">
      Join us on the trail and in the community. MVTA hosts group hikes, monthly board
      meetings, and participates in local events throughout the year.
    </p>

    <ul class="mt-12 space-y-6 list-none m-0 p-0">
      {events.map((event) => (
        <li class="card">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{event.name}</h2>
            <span class="tag-pill shrink-0">{event.date}</span>
          </div>
          {event.location && (
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{event.location}</p>
          )}
          <p class="mt-3 text-gray-600 dark:text-gray-400">{event.description}</p>
        </li>
      ))}
    </ul>

    <div class="mt-12 card bg-brand-50 dark:bg-brand-900/30 border-brand-200 dark:border-brand-700">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Stay in the Loop</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        MVTA members receive our newsletter with upcoming events, trail news, and volunteer
        opportunities. <a href="/contact" class="text-brand-600 dark:text-brand-400 hover:underline">Join MVTA</a> to
        get updates delivered to your inbox.
      </p>
    </div>
  </main>
</BaseLayout>
