---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';

const events = (await getCollection('events')).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
);
---

<BaseLayout
  title="Events"
  description="Upcoming events from the Meadow Vista Trails Association — group hikes, board meetings, and community gatherings."
>
  <main class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Events</h1>
    <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">
      Join us on the trail and in the community. MVTA hosts group hikes, monthly board
      meetings, and participates in local events throughout the year.
    </p>

    <ul class="mt-12 space-y-6 list-none m-0 p-0">
      {events.map((event) => (
        <li class="card">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{event.data.title}</h2>
            <span class="tag-pill shrink-0"><FormattedDate date={event.data.date} format="short" /></span>
          </div>
          {event.data.location && (
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{event.data.location}</p>
          )}
          <p class="mt-3 text-gray-600 dark:text-gray-400">{event.data.description}</p>
        </li>
      ))}
    </ul>

    <div class="mt-12 card bg-brand-50 dark:bg-brand-900/30 border-brand-200 dark:border-brand-700">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Stay in the Loop</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        MVTA members receive our newsletter with upcoming events, trail news, and volunteer
        opportunities. <a href="/contact" class="text-brand-600 dark:text-brand-400 hover:underline">Join MVTA</a> to
        get updates delivered to your inbox.
      </p>
    </div>
  </main>
</BaseLayout>
