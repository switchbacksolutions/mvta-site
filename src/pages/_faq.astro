---
import BaseLayout from '@/layouts/BaseLayout.astro';

const faqs = [
  {
    question: 'What are the main threats to natural habitats and ecosystems?',
    answer: 'Natural habitats and ecosystems face threats such as habitat destruction and fragmentation, climate change, pollution, invasive species, overexploitation of resources, and unsustainable land use practices.',
  },
  {
    question: 'What are some effective conservation strategies for saving nature?',
    answer: 'Effective strategies include establishing protected areas, implementing habitat restoration projects, promoting sustainable resource use, regulating wildlife trade, and increasing public awareness and education about conservation.',
  },
  {
    question: 'Why is it important to save nature?',
    answer: 'Preserving nature protects biodiversity and ecosystems while ensuring the well-being of future generations. Nature supplies critical services including clean air, water, climate regulation, and crop pollination that all life depends upon.',
  },
  {
    question: 'What are the benefits of saving nature for communities and society?',
    answer: 'Conservation provides ecosystem services such as clean air and water, food security, climate regulation, and cultural and recreational opportunities, while also supporting local economies and quality of life.',
  },
  {
    question: 'How can individuals contribute to saving nature in their daily lives?',
    answer: 'People can reduce their ecological footprint by conserving water and energy, minimizing waste, supporting sustainable products, eating less meat, and advocating for protective environmental policies.',
  },
  {
    question: 'What role do governments and policymakers play in saving nature?',
    answer: 'Governments enact and enforce protective laws, designate conservation zones and protected areas, invest in conservation initiatives, and integrate environmental considerations into policy and decision-making processes.',
  },
  {
    question: 'How can businesses contribute to saving nature?',
    answer: 'Businesses can adopt sustainable practices, reduce resource consumption and waste, support conservation projects through corporate giving, and engage in meaningful corporate social responsibility programs.',
  },
  {
    question: 'What are some success stories of saving nature?',
    answer: 'There are many success stories, including the recovery of endangered species such as the bald eagle and the gray wolf, and the restoration of degraded ecosystems such as wetlands and forests through coordinated conservation efforts.',
  },
];
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about conservation, trail stewardship, and protecting our natural environment — from the Meadow Vista Trails Association."
>
  <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Frequently Asked Questions</h1>
    <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">
      Questions about conservation, nature stewardship, and protecting the environment we
      all love to explore.
    </p>

    <dl class="mt-12 space-y-8">
      {faqs.map((faq) => (
        <div class="card">
          <dt class="text-lg font-semibold text-gray-900 dark:text-white">{faq.question}</dt>
          <dd class="mt-3 text-gray-600 dark:text-gray-400">{faq.answer}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-12 text-center">
      <p class="text-gray-600 dark:text-gray-400">Have a question not answered here?</p>
      <a href="/contact" class="mt-4 inline-block btn-primary">Contact Us</a>
    </div>
  </main>
</BaseLayout>
