# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# Public site URL — used in sitemap and RSS feed
# Must match the `site` value in astro.config.mjs
PUBLIC_SITE_URL=https://example.com

# Site metadata
PUBLIC_SITE_TITLE="My Astro Blog"
PUBLIC_SITE_DESCRIPTION="A personal blog built with Astro"

# Analytics (optional)
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# PUBLIC_PLAUSIBLE_DOMAIN=example.com

# Stripe — online membership payments
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret — from https://dashboard.stripe.com/webhooks
# Point the webhook at: https://your-site.netlify.app/.netlify/functions/stripe-webhook
# Events to send: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# Email notifications for payments (uses Resend — https://resend.com, free tier available)
RESEND_API_KEY=re_...
# Who receives the payment notification email (e.g. the treasurer)
TREASURER_EMAIL=treasurer@meadowvistatrails.org
# The "from" address — must be a verified Resend sender domain
FROM_EMAIL=MVTA Website <noreply@meadowvistatrails.org>
